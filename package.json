{
  "name": "cafes-app-backend",
  "version": "0.1.0",
  "description": "Backend API for CafES APP",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.json && vite build",
