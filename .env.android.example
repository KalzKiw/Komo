# Copia este archivo como .env.android.local o exporta la variable antes de compilar.
# El APK no puede usar el proxy de Vite (/api). Necesita una API accesible desde el movil.
#
# Ejemplos:
# - API publicada: https://komo-api.tudominio.es
# - API local en la red del colegio: http://192.168.30.20:3001

VITE_API_BASE_URL=https://TU_API_PUBLICA_O_IP_LOCAL
